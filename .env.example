# Documentation Site — Environment Variables
# Copy to .env and fill in values before running.

# Optional: Site base URL (used for canonical links and sitemap)
# SITE_URL=https://docs.example.com

# Optional: Google Analytics measurement ID
# PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Algolia DocSearch credentials (for full-text search)
# PUBLIC_ALGOLIA_APP_ID=
# PUBLIC_ALGOLIA_API_KEY=
# PUBLIC_ALGOLIA_INDEX_NAME=
